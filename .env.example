# Environment Variables for GuardianX
# Copy this file to .env and fill in your actual API keys

# NVIDIA AI API Key - Get from https://build.nvidia.com/
NVIDIA_API_KEY="your_nvidia_api_key_here"

# HaveIBeenPwned API Key - Get from https://haveibeenpwned.com/API/Key
HIBP_API_KEY="your_haveibeenpwned_api_key_here"

# Security Note: Never commit .env files to version control!
# This file contains sensitive API keys that should remain private.